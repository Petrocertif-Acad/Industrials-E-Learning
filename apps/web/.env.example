# Copiez ce fichier en `.env` et renseignez des valeurs réelles.
# Ne jamais committer de vraies valeurs (secrets, mots de passe) dans ce dépôt.

# Connexion PostgreSQL (voir docker/docker-compose.yml pour le développement local)
DATABASE_URL="postgresql://atti:atti@localhost:5432/atti?schema=public"

# Auth.js — générez une valeur avec `npx auth secret` ou `openssl rand -base64 33`
AUTH_SECRET="changeme-generate-a-real-secret"

# URL publique de l'application (utilisée par Auth.js pour les redirections)
AUTH_URL="http://localhost:3000"

# Stockage documentaire compatible S3 (MinIO en local, voir docker/docker-compose.yml).
# STORAGE_PUBLIC_ENDPOINT n'est nécessaire que lorsque l'application tourne
# elle-même dans Docker : les liens signés doivent pointer vers une adresse
# joignable par le navigateur, pas vers le nom d'hôte interne au réseau Docker.
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_PUBLIC_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="atti-documents"
STORAGE_ACCESS_KEY_ID="atti"
STORAGE_SECRET_ACCESS_KEY="atti-minio-local"
STORAGE_FORCE_PATH_STYLE="true"
